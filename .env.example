# CUDA Ingest Pipeline - Environment Variables Template
# Copy this file to .env and fill in your values

# Neon PostgreSQL Connection URI
# Get this from your Neon console: https://neon.tech
NEON_URI=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# NOTE: GitHub Actions restricts custom secrets from starting with GITHUB_
# Use TOKEN_GITHUB instead of GITHUB_TOKEN
TOKEN_GITHUB=ghp_xxxxxxxxxxxxxxxxxxxx

# MiniMax API Key
# Get this from your MiniMax console: https://minimaxi.chat
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_API_BASE=https://api.minimaxi.chat/v1

# Pipeline Configuration (optional)
BATCH_SIZE=10
# Repos to scan per run for code hits (default 50; use 8–12 for quick local runs)
REPOS_PER_RUN=50
# Optional: lower inter-request delay for local dev (default 2.0s; try 0.6)
# GITHUB_REQUEST_DELAY_SECONDS=0.6
MAX_KERNEL_LENGTH=50000
MIN_KERNEL_LENGTH=50

# Dry Run Mode (for testing)
DRY_RUN=false
